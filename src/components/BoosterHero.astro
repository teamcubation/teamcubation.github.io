---
import { Image } from 'astro:assets'
import Container from './Container.astro'
import Button from './Button.astro'
import NumberCard from './NumberCard.astro'
import boosterHeroImg from '../assets/booster_hero.png'

interface Point {
  title: string
  subtitle: string
}

interface Props {
  highlight?: string
  subtitle?: string
  highlight2?: string
  ctaLabel?: string
  ctaHref?: string
  brochureLabel?: string
  brochureHref?: string
  strip?: string
  points?: Point[]
}

const {
  highlight = 'Tus equipos, guiados por nuestros mentores, automatizan tareas repetitivas, liberando horas para enfocarse en el negocio. Eficientización + entrenamiento.',
  subtitle = 'Un programa de entrenamiento on-the-job, ágil y humano, para que tu equipo aprenda a usar IA en sus procesos reales. Sin fricciones ni depender de IT: con BoosterAI cada persona potencia su propio "metro cuadrado" y multiplica el impacto en la organización.',
  highlight2 = 'Ya entrenamos a la IA… es hora de entrenar a los humanos.',
  ctaLabel = 'Agendar Reunión',
  ctaHref = '/contacto',
  brochureLabel = 'Brochure',
  brochureHref = 'https://tq-prod-api-addonsstack-1hk-tqstoragebucketbucket-18dt1u3ncepot.s3.us-east-1.amazonaws.com/Booster+AI+BIZ+-+Website.pdf',
  strip = 'La IA se aprende con personas y nuestro Booster AI hace eso: empoderar a tus equipos, de humano a humano.',
  points = [
    { title: 'Comprender', subtitle: 'El potencial y los límites de la IA, y explorar herramientas como n8n, Power Automate y Agentes.' },
    { title: 'Diseñar', subtitle: 'Los primeros procesos con IA, con apoyo de mentoría personalizada.' },
    { title: 'Dominar', subtitle: 'La confianza para explorar y aplicar IA, sin depender del área de IT.' },
  ],
} = Astro.props

// Number + color per card are fixed across languages (positional).
const numbers = ['01', '02', '03']
const colors = ['#1FB6FF', '#B636FF', '#4B1FFC']
---

<section class="overflow-x-clip">
  <div class="relative h-[200px] w-full overflow-hidden">
    <img src="/head_title.png" alt="" aria-hidden="true" class="block h-full w-full object-cover xl:hidden" />
    <Image src={boosterHeroImg} alt="" aria-hidden="true" widths={[1280, 1920, 2560]} sizes="100vw" class="hidden h-full w-full object-cover object-right xl:block" />
    <img src="/rectangle_violet.png" alt="" aria-hidden="true" class="pointer-events-none absolute left-0 top-0 h-[160px] w-[160px] xl:h-auto xl:w-[180px]" />
    <img src="/rectangle_violet_2.png" alt="" aria-hidden="true" class="pointer-events-none absolute bottom-0 right-0 h-[160px] w-[160px] xl:h-auto xl:w-[180px]" />
  </div>

  <Container class="!max-w-[960px] py-[60px]">
    <div class="flex flex-col gap-6 min-[800px]:flex-row min-[800px]:items-center min-[800px]:justify-between">
      <h1 class="!text-[48px] font-extrabold !leading-[1.3] !tracking-[-1.44px] text-content-primary">Booster<span class="bg-clip-text text-transparent" style="background-image: linear-gradient(to right, #B636FF 0%, #6D00FF 50%, #00B2FF 100%);">AI</span></h1>

      <div class="flex shrink-0 gap-3 max-[800px]:w-full max-[800px]:flex-col">
        <Button href={ctaHref} variant="primary" radius={[24, 32, 0, 24]} class="gap-2 !bg-violet-main pt-[13px] pr-[24px] pb-[13px] pl-[20px] text-[14px] font-extrabold leading-none hover:!bg-violet-main max-[800px]:w-full">
          <img src="/calendar.svg" alt="" aria-hidden="true" class="h-6 w-6" />
          {ctaLabel}
        </Button>

        <Button href={brochureHref} target="_blank" rel="noopener noreferrer" radius={[24, 24, 24, 0]} class="gap-2 border-0 bg-gray-light pt-[13px] pr-[24px] pb-[13px] pl-[20px] text-[14px] font-extrabold leading-none max-[800px]:w-full" style="color: var(--color-content-primary)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
            <path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" />
          </svg>
          {brochureLabel}
        </Button>
      </div>
    </div>

    <p class="mt-8 text-[20px] font-extrabold leading-[1.5] text-content-primary">{highlight}</p>
    <p class="mt-6 text-[19px] leading-[1.8] tracking-[0px] text-content-primary" style="font-family: 'Inter', sans-serif; font-weight: 500;">{subtitle}</p>
    <p class="mt-8 text-[20px] font-extrabold leading-[1.5] text-content-primary">{highlight2}</p>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {points.map((p, i) => (
        <NumberCard number={numbers[i]} title={p.title} subtitle={p.subtitle} color={colors[i]} reveal={i === 0 ? 'left' : i === 2 ? 'right' : 'up'} />
      ))}
    </div>

    <div data-reveal class="mt-8 rounded-lg px-8 py-5 text-center text-[16px] leading-[1.4] text-white" style="font-family: 'Inter', sans-serif; font-weight: 600; background-image: linear-gradient(to right, #B636FF 0%, #6D00FF 50%, #00B2FF 100%);">{strip}</div>
  </Container>
</section>
