---
interface Props {
  number: string
  title: string
  subtitle: string
  color?: string
  reveal?: string
}

const { number, title, subtitle, color = 'var(--color-primary)', reveal } = Astro.props
---

<article data-reveal={reveal} class="flex flex-col rounded-lg border border-border-main bg-white px-6 pt-12 pb-10">
  <div class="flex items-end gap-[6px]">
    <span class="text-[70px] font-extrabold leading-[0.83]" style={`color: ${color};`}>{number}</span>
    <span class="block" style={`width: 24px; height: 12px; background-color: ${color}; border-radius: 6px 10px 0px 6px;`}></span>
  </div>
  <h3 class="mt-8 text-[20px] font-extrabold leading-none tracking-[0px] text-content-primary">{title}</h3>
  <p class="mt-5 text-[14px] leading-[1.4] tracking-[0px] text-content-secondary" style="font-family: 'Inter', sans-serif; font-weight: 400;">{subtitle}</p>
</article>
