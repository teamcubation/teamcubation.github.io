---
interface Props {
  icon?: string
  title: string
  description: string
  titleClass?: string
  class?: string
  reveal?: string
}

const { icon = '/check.png', title, description, titleClass = 'text-primary', class: className, reveal } = Astro.props
---

<article data-reveal={reveal} class:list={['flex h-full flex-col rounded-lg border border-border-main bg-white px-6 py-8', className]}>
  <img src={icon} alt="" aria-hidden="true" class="h-12 w-12" />
  <h3 class:list={['mt-4 text-[18px] font-extrabold leading-[1.2]', titleClass]}>{title}</h3>
  <p class="mt-2 text-[14px] leading-[1.5] text-content-secondary" style="font-family: 'Inter', sans-serif; font-weight: 400;">{description}</p>
</article>
