---
import Container from './Container.astro'
import Button from './Button.astro'
import NumberCard from './NumberCard.astro'

interface Point {
  title: string
  subtitle: string
}

interface Props {
  subtitle?: string
  highlight?: string
  ctaLabel?: string
  ctaHref?: string
  points?: Point[]
}

const {
  subtitle = 'Somos la primera Software+Team Factory, implementamos proyectos tecnológicos para nuestros clientes mientras aceleramos el desarrollo de habilidades tech de sus potenciales colaboradores.',
  highlight = 'Construimos el software que necesitas hoy mientras incubamos tu equipo del mañana.',
  ctaLabel = 'Agendar Reunión',
  ctaHref = 'https://teamcubation.pipedrive.com/scheduler/kOBXpjiw/meeting',
  points = [
    {
      title: 'Desarrollo de software llave en mano',
      subtitle: 'Creamos soluciones a medida que cumplen con tus necesidades específicas, garantizando delivery.',
    },
    {
      title: 'Formación en proyectos reales',
      subtitle: 'Los juniors, con formación en programación, ganan experiencia en proyectos reales junto a nuestros seniors, acelerando su crecimiento profesional y cultura de trabajo.',
    },
    {
      title: 'Identificación y selección de talento',
      subtitle: 'Seleccionamos a los talentos mejor adaptados a tu cultura, quienes, al finalizar el proyecto, ya están entrenados y preparados para integrarse a tu equipo sin fricción.',
    },
  ],
} = Astro.props

// Number + color per card are fixed across languages (positional).
const numbers = ['01', '02', '03']
const colors = ['#dcdf30', '#ff4933', '#ff2e5b']
---

<section class="overflow-x-clip">
  <div class="relative h-[200px] w-full overflow-hidden">
    <img src="/incubation_hero_sx.png" alt="" aria-hidden="true" class="block h-full w-full object-cover xl:hidden" />
    <img src="/incubation_hero.png" alt="" aria-hidden="true" class="hidden h-full w-full object-cover xl:block" />
    <img src="/orange.png" alt="" aria-hidden="true" class="pointer-events-none absolute left-0 top-0 h-[160px] w-[160px] xl:h-auto xl:w-[180px]" />
    <img src="/decoration.png" alt="" aria-hidden="true" class="pointer-events-none absolute bottom-0 right-0 h-[160px] w-[160px] xl:h-auto xl:w-[180px]" />
  </div>

  <Container class="!max-w-[960px] py-[60px]">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <h1 class="!text-[48px] font-extrabold !leading-[1.3] !tracking-[-1.44px] text-content-primary">Incubati<span class="bg-clip-text text-transparent" style="margin-left: 2px;
        background-image: linear-gradient(to right, #FFA232 0%, #FF5633 23%, #FF4933 50%, #FF2E5B 100%);">ON</span></h1>

      <Button href={ctaHref} target="_blank" rel="noopener noreferrer" variant="primary" radius={[24, 32, 0, 24]} class="shrink-0 gap-2 pt-[13px] pr-[24px] pb-[13px] pl-[20px] text-[14px] font-extrabold leading-none">
        <img src="/calendar.svg" alt="" aria-hidden="true" class="h-6 w-6" />
        {ctaLabel}
      </Button>
    </div>

    <p class="mt-8  text-[19px] leading-[1.8] tracking-[0px] text-content-primary" style="font-family: 'Inter', sans-serif; font-weight: 500;">{subtitle}</p>
    <p class="mt-8  text-[20px] font-extrabold leading-[1.5] text-content-primary">{highlight}</p>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {points.map((p, i) => (
        <NumberCard number={numbers[i]} title={p.title} subtitle={p.subtitle} color={colors[i]} reveal={i === 0 ? 'left' : i === 2 ? 'right' : 'up'} />
      ))}
    </div>
  </Container>

  <div class="relative h-[400px] w-full overflow-hidden max-[800px]:h-[300px]">
    <img src="/incubation_1_sx.png" alt="" aria-hidden="true" class="block h-full w-full object-cover min-[800px]:hidden" />
    <img src="/incubation_1.png" alt="" aria-hidden="true" class="hidden h-full w-full object-cover min-[800px]:block" />
    <img src="/rectangle_yellow.png" alt="" aria-hidden="true" class="pointer-events-none absolute bottom-0 left-0 h-[160px] w-[160px] min-[800px]:h-[240px] min-[800px]:w-[240px] min-[1280px]:h-[320px] min-[1280px]:w-[320px] min-[1440px]:h-[400px] min-[1440px]:w-[400px]" />
    <img src="/Decoration_Red.png" alt="" aria-hidden="true" class="pointer-events-none absolute right-0 top-0 h-[160px] w-[160px] min-[800px]:h-[240px] min-[800px]:w-[240px] min-[1280px]:h-[320px] min-[1280px]:w-[320px] min-[1440px]:h-[400px] min-[1440px]:w-[400px]" />
  </div>
</section>
