---
interface Member {
  name: string
  role: string
  description: string
  avatar: string
  linkedin?: string
}

interface Props {
  members?: Member[]
  linkedinLabel?: string
}

const { members = [], linkedinLabel = 'LinkedIn' } = Astro.props
---

<div class="team-carousel relative w-full overflow-hidden">
  <div class="team-track flex w-max gap-[34px]">
    {[...members, ...members].map((m, i) => (
      <article
        class="flex h-[395px] w-[282px] shrink-0 flex-col rounded-lg border border-border-main bg-white p-8"
        aria-hidden={i >= members.length ? 'true' : undefined}
      >
        <img src={m.avatar} alt={m.name} class="h-[140px] w-[140px] rounded-[32px_32px_32px_0px] object-cover" loading="lazy" />

        <h3 class="mt-4 text-[18px] font-extrabold leading-[1.2] text-content-primary">{m.name}</h3>
        <p class="mt-1 text-[14px] font-extrabold text-content-secondary">{m.role}</p>
        <p class="mt-3 text-[14px] leading-[1.5] text-content-secondary" style="font-family: 'Inter', sans-serif; font-weight: 400;">{m.description}</p>

        <a
          href={m.linkedin || '#'}
          target="_blank"
          rel="noopener"
          tabindex={i >= members.length ? -1 : undefined}
          class="mt-4 inline-flex items-center gap-2 self-start rounded-[16px_16px_0px_16px] bg-primary px-3 py-2 text-[12px] leading-none text-white hover:bg-primary-hover"
        >
          <svg viewBox="0 0 448 512" fill="currentColor" class="h-[10px] w-[10px]" aria-hidden="true">
            <path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z" />
          </svg>
          {linkedinLabel}
        </a>
      </article>
    ))}
  </div>
</div>

<style>
  .team-track {
    animation: team-scroll 40s linear infinite;
  }

  .team-carousel:hover .team-track {
    animation-play-state: paused;
  }

  @keyframes team-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
