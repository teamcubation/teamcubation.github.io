---
import Container from './Container.astro'

interface Props {
  tag?: string
  title?: string
  description?: string
}

const {
  tag = 'Caso de éxito',
  title = 'Historias de éxito',
  description = 'Descubre cómo hemos colaborado con Mercado Libre, no solo desarrollando software, sino también desarrollando talento para que pueda formar parte de sus equipos con resultados excepcionales.',
} = Astro.props

// Brand data — same across languages. Logo/video added later.
const clientLogo = '/logos/mercado_libre.png'
const videoSrc = '/mp.mp4'
---

<section id="casos-de-exito" class="scroll-mt-24 py-12">
  <Container class="!max-w-[1240px]">
    <!-- Case study: text + video -->
    <div class="grid items-center gap-[60px] xl:grid-cols-[650px_1fr]">
      <div>
        <span class="inline-block rounded-[16px_20px_0px_16px] bg-warning-light px-[10px] py-2 text-[10px] font-extrabold uppercase leading-none tracking-[0.3px] text-content-primary" style="font-family: 'Inter', sans-serif;">{tag}</span>

        <h2 class="mt-5 text-[32px] font-extrabold leading-[1.3] tracking-[-0.96px] text-content-primary">{title}</h2>

        <p class="mt-4 text-[20px] leading-[1.5] tracking-[0px] text-content-primary" style="font-family: 'Inter', sans-serif; font-weight: 400;">{description}</p>

        <div class="mt-8">
          {clientLogo ? (
            <img src={clientLogo} alt="Mercado Libre" class="object-contain" style="width: 190px; height: 50px;" />
          ) : (
            <div class="h-10 w-[150px] rounded bg-gray-light"></div>
          )}
        </div>
      </div>

      <div class="w-full overflow-hidden rounded-2xl xl:w-[490px]" style="aspect-ratio: 490 / 275;">
        {videoSrc ? (
          <video src={videoSrc} controls aria-label={title} class="h-full w-full object-cover"></video>
        ) : (
          <div class="h-full w-full" style="background: linear-gradient(160deg, #3a0a52 0%, #1a0426 100%);"></div>
        )}
      </div>
    </div>
  </Container>
</section>
