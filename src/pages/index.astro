---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Hero from '../components/Hero.astro'
import LogoBar from '../components/LogoBar.astro'
import Services from '../components/Services.astro'
import Product from '../components/Product.astro'
import SuccessStories from '../components/SuccessStories.astro'
import Testimonials from '../components/Testimonials.astro'
import CtaBanner from '../components/CtaBanner.astro'
import Team from '../components/Team.astro'
import heroImage from '../assets/hero_image_es.png'
---

<Layout
  title="Teamcubation | Desarrolladores de Experiencia"
  description="Tus colaboradores desarrollan habilidades tecnológicas con acompañamiento experto y entrenamientos on the job. Todos nuestros servicios se basan en proyectos reales, formando talento nuevo o fortaleciendo el equipo actual de tu empresa."
  ogImage="/teamcubation_og.jpg"
  alternateLanguages={[
    { lang: 'es', href: 'https://teamcubation.com/' },
    { lang: 'en', href: 'https://teamcubation.com/en' },
    { lang: 'pt', href: 'https://teamcubation.com/pt' },
  ]}
>
  <Header lang="es" currentPage="/" />

  <main>
    <Hero image={heroImage} />
    <LogoBar />
    <Services />
    <Product />
    <SuccessStories />
    <Testimonials />
    <CtaBanner />
    <Team />
  </main>

  <Footer lang="es" />
</Layout>
