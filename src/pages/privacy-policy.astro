  .legal .table-wrap { overflow-x: auto; margin-bottom: 18px; }
  .legal table { border-collapse: collapse; width: 100%; font-size: 14px; }
  .legal th, .legal td { border: 1px solid var(--color-border-main); padding: 10px 12px; text-align: left; }
  .legal th { background: var(--color-gray-light); color: var(--color-content-primary); font-weight: 700; }
  .legal td.empty { text-align: center; color: var(--color-content-light); }
  .legal hr { border: 0; border-top: 1px solid var(--color-border-main); margin: 48px 0; }
