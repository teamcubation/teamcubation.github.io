    color: var(--color-content-light);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    margin-bottom: 32px;
  }
  .legal h2 {
    color: var(--color-content-primary);
    font-size: 20px;
    font-weight: 800;
