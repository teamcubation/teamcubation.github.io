  .legal em { font-style: italic; }
  .legal a { color: var(--color-primary); text-decoration: underline; word-break: break-word; }
  .legal a:hover { color: var(--color-primary-hover); }
  .legal ol, .legal ul { margin: 0 0 18px; padding-left: 26px; list-style-position: outside; }
  .legal ol { list-style-type: decimal; }
  .legal ul { list-style-type: disc; }
  .legal li { margin-bottom: 10px; padding-left: 4px; }
